{
  "name": "manada",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @manada/web dev",
    "build": "pnpm --filter @manada/web build",
    "start": "pnpm --filter @manada/web start",
    "lint": "pnpm --filter @manada/web lint",
    "typecheck": "pnpm --filter @manada/web exec tsc --noEmit",
    "dev:web": "pnpm --filter @manada/web dev",
    "dev:backend": "pnpm --filter @manada/backend dev",
    "build:backend": "pnpm --filter @manada/backend build",
    "migrate:backend": "pnpm --filter @manada/backend exec medusa db:migrate",
    "seed:backend": "pnpm --filter @manada/backend exec medusa exec ./src/scripts/seed.ts"
  }
}
