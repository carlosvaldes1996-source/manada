# Manada monorepo — configuración pnpm
# Patrones de hoist requeridos por Medusa v2 (admin/framework) bajo pnpm.
# Deben vivir en la raíz del workspace para aplicar a apps/backend.
public-hoist-pattern[]=*@medusajs/*
public-hoist-pattern[]=@tanstack/react-query
public-hoist-pattern[]=react-i18next
public-hoist-pattern[]=react-router-dom
