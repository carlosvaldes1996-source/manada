{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @manada/backend build && cd apps/backend/.medusa/server && npm install --no-audit --no-fund"
  },
  "deploy": {
    "startCommand": "cd apps/backend/.medusa/server && npm run start",
    "preDeployCommand": "cd apps/backend/.medusa/server && npx medusa db:migrate",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
