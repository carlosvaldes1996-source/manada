# Plantilla de entorno de @manada/web. Copia a .env.local y completa los valores.
#
# Backend Medusa local (ver apps/backend/DEV.md para levantarlo).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
#
# Publishable key de storefront. La crea el seed; obtenerla con:
#   psql -d medusa_manada -tAc "select token from api_key where type='publishable';"
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxx
